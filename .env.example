# ============================================
# VELOX CARS - Variables d'environnement
# ============================================
# 📋 Comment utiliser ce fichier :
#   1. Copiez-le : cp .env.example .env.local
#   2. Modifiez .env.local avec vos clés
#   3. Redémarrez : npm run dev
# ⚠️ Le fichier .env.local ne doit JAMAIS être commité dans git.
# ============================================


# ============================================
# 🤖 OCR Provider — Reconnaissance documents
# ============================================
# Choisissez parmi :
#   • simulation  → mode démo (par défaut, aucune clé requise)
#   • ocrspace ⭐  → GRATUIT 25 000 docs/mois (RECOMMANDÉ)
#   • tesseract   → 100% navigateur, gratuit illimité (lent)
#   • mindee      → payant (mais excellent pour MA)
#   • google      → 1 000 docs/mois gratuit (carte bancaire requise)
VITE_OCR_PROVIDER=simulation


# ============================================
# ⭐ OCR.space (RECOMMANDÉ — 100% gratuit)
# ============================================
# ✅ 25 000 documents par mois GRATUIT
# ✅ Aucune carte bancaire requise
# ✅ Supporte français + arabe
# ✅ Inscription en 30 secondes
#
# 📝 Comment obtenir votre clé GRATUITE :
#   1. Allez sur : https://ocr.space/ocrapi/freekey
#   2. Entrez votre email
#   3. La clé arrive immédiatement par email
#   4. Collez-la ci-dessous
#
# 💡 Sans clé personnelle, vous pouvez tester avec "helloworld"
#    mais c'est limité à quelques requêtes
VITE_OCRSPACE_API_KEY=helloworld


# ============================================
# Mindee API (premium — payant pour Maroc)
# ============================================
# ⚠️ Le modèle Morocco ID n'est plus dans le tier gratuit.
# Si vous avez un compte payant : https://platform.mindee.com
VITE_MINDEE_API_KEY=


# ============================================
# Google Cloud Vision (alternative)
# ============================================
# ⚠️ Nécessite une carte bancaire (même pour le tier gratuit)
# 1 000 requêtes/mois gratuites ensuite payant
# https://console.cloud.google.com
VITE_GOOGLE_VISION_API_KEY=
